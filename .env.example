# CodeLens AI - Enterprise Environment Variables
# Copy to .env and configure for your deployment

# ─── Required ───────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# ─── Webhook ───────────────────────────────────────────────────
WEBHOOK_SECRET=your-github-webhook-secret

# ─── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT=100
RATE_WINDOW=60
ANONYMOUS_LIMIT=20

# ─── Audit Logging ─────────────────────────────────────────────
AUDIT_RETENTION_DAYS=90

# ─── Encryption ─────────────────────────────────────────────────
# Base64-encoded 32-byte key for AES-256-GCM
# Generate with: python3 -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
ENCRYPTION_KEY=

# ─── Ports ─────────────────────────────────────────────────────
PORT=8090
FRONTEND_PORT=3000
REDIS_PORT=6379
PROMETHEUS_PORT=9090

# ─── SAML SSO Configuration ─────────────────────────────────────
# Comma-separated list of Entity IDs for multiple IdPs
CODELENS_SAML_ENTITY_IDS=https://idp.example.com/saml
CODELENS_SAML_1_SSO_URL=https://idp.example.com/saml/sso
CODELENS_SAML_1_X509_CERT=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----
CODELENS_SAML_1_LABEL=Enterprise SSO

# ─── OIDC SSO Configuration ─────────────────────────────────────
# Comma-separated list of issuers for multiple IdPs
CODELENS_OIDC_ISSUERS=https://accounts.google.com
CODELENS_OIDC_1_CLIENT_ID=your-client-id
CODELENS_OIDC_1_CLIENT_SECRET=your-client-secret
CODELENS_OIDC_1_AUTH_ENDPOINT=https://accounts.google.com/o/oauth2/v2/auth
CODELENS_OIDC_1_TOKEN_ENDPOINT=https://oauth2.googleapis.com/token
CODELENS_OIDC_1_USERINFO_ENDPOINT=https://openidconnect.googleapis.com/userinfo
CODELENS_OIDC_1_JWKS_URI=https://www.googleapis.com/oauth2/v3/certs
CODELENS_OIDC_1_LABEL=Google Workspace
